# Backend Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Database
MONGODB_URI=mongodb://localhost:27017/senmool
MONGODB_USER=admin
MONGODB_PASS=change_me_in_production

# MQTT Broker
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USER=admin
MQTT_PASS=change_me_in_production

# Authentication
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=24h

# Twilio (SMS Notifications)
TWILIO_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_NUMBER=+1234567890
EMERGENCY_CONTACT=+221781234567

# API Configuration
API_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://dashboard.senmool.sn

# Firebase (FCM Notifications)
FIREBASE_PROJECT_ID=senmool-project
FIREBASE_PRIVATE_KEY_ID=key_id
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
FIREBASE_CLIENT_EMAIL=firebase@senmool.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=client_id

# ML Services
ML_API_URL=http://localhost:5000
ML_FALL_DETECTION_ENABLED=true
ML_ANOMALY_DETECTION_ENABLED=true
FALL_DETECTION_THRESHOLD=0.7
ANOMALY_ALERT_COOLDOWN=300

# Device Configuration
GPS_UPDATE_INTERVAL=5000
SENSOR_UPDATE_INTERVAL=2000
DATA_PUBLISH_INTERVAL=30000

# Risk Zones (coordinates)
RISK_ZONE_LATITUDE_1=14.7473
RISK_ZONE_LONGITUDE_1=-17.5289
